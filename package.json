{
  "name": "meu-projeto-cypress",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "cypress run --browser chrome",
    "report:merge": "mochawesome-merge cypress/reports/*.json > cypress/reports/merged.json",
    "report:generate": "marge cypress/reports/merged.json --reportDir cypress/reports --inline",
    "report": "npm run report:merge && npm run report:generate",
    "test:login": "cypress run --spec cypress/e2e/login.cy.js --browser chrome",
    "test:inventory": "cypress run --spec cypress/e2e/inventory.cy.js --browser chrome",
    "test:inventory-item": "cypress run --spec cypress/e2e/inventory-item.cy.js --browser chrome",
    "test:cart": "cypress run --spec cypress/e2e/cart.cy.js --browser chrome",
    "test:checkout": "cypress run --spec cypress/e2e/checkout.cy.js --browser chrome",
    "test:open": "cypress open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "cypress": "^15.12.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "prettier": "^3.8.1"
  }
}
